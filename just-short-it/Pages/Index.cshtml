@page "{Id?}"
@model JustShortIt.Pages.IndexModel
@{
    ViewData["Title"] = "Startpage";
}

<div class="has-text-centered my-6 px-4">
    @if (Model.Id is null)
    {
        <h1 class="title is-1 is-spaced">Just Short It!</h1>
        <h2 class="subtitle is-2">a simple one user URL shortener</h2>
        <a class="button is-primary is-medium" asp-page="Urls">short 'em URLs</a>
    }
    else
    {
        <p class="has-text-danger">@Model.ErrorMessage</p>
    }
</div>