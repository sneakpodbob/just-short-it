@page
@model JustShortIt.Pages.RedirectsModel
@{
    ViewData["Title"] = "Manage Redirects";
}

<div class="columns is-centered is-multiline my-6 px-4">
    <div class="column is-full has-text-centered">
        <h1 class="title is-2">Manage Redirects</h1>
    </div>

    <div class="column is-full">
        @if (!Model.Redirects.Any())
        {
            <p class="has-text-centered has-text-grey">No active redirects found.</p>
        }
        else
        {
            <div class="table-container">
                <table class="table is-fullwidth is-striped is-hoverable">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Target</th>
                            <th>Expires</th>
                            <th class="has-text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var redirect in Model.Redirects)
                        {
                            var expiresAt = DateTimeOffset.FromUnixTimeSeconds(redirect.ExpiresAtUtc).UtcDateTime;
                            var isNeverExpiring = expiresAt > DateTime.UtcNow.AddYears(100);
                            <tr>
                                <td class="is-vcentered">
                                    <code>@redirect.Id</code>
                                </td>
                                <td class="is-vcentered jsi-td-truncate">
                                    <span title="@redirect.Target">@redirect.Target</span>
                                </td>
                                <td class="is-vcentered">
                                    @if (isNeverExpiring)
                                    {
                                        <span>Never</span>
                                    }
                                    else
                                    {
                                        <time datetime="@expiresAt.ToString("o")">@expiresAt.ToString("yyyy-MM-dd HH:mm") UTC</time>
                                    }
                                </td>
                                <td class="is-vcentered">
                                    <div class="buttons is-right">
                                        <a class="button is-small is-info"
                                           asp-page="Inspect"
                                           asp-route-id="@redirect.Id"
                                           asp-route-returnTo="redirects"
                                           title="Inspect @redirect.Id">
                                            <span class="icon">
                                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
                                                    <path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>
                                                </svg>
                                            </span>
                                        </a>
                                        <form method="post" asp-page-handler="Delete" class="jsi-form-inline">
                                            <input type="hidden" name="id" value="@redirect.Id" />
                                            <button type="submit"
                                                    class="button is-small is-danger"
                                                    title="Delete @redirect.Id"
                                                    onclick="return confirm('Delete redirect \'@redirect.Id\'?')">
                                                <span class="icon">
                                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
                                                        <path d="M9 3v1H4v2h1v13a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V6h1V4h-5V3H9zm0 5h2v9H9V8zm4 0h2v9h-2V8z"/>
                                                    </svg>
                                                </span>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="column is-full has-text-centered">
        <a class="button is-primary is-medium" asp-page="Urls">Back to URLs</a>
    </div>
</div>
